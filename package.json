{
  "name": "@jcamatta/veto",
  "version": "0.1.0",
  "description": "AI reviewer agents for staged changes — pre-commit gate with structured findings",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "veto": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "type-coverage": "type-coverage --at-least 95 --strict --ignore-files \"dist/**\"",
    "check": "npm run lint && npm run typecheck && npm run coverage && npm run type-coverage",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "effect": "^3.21.3",
    "picomatch": "^4.0.4",
    "tinyglobby": "^0.2.17",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@types/node": "^20.19.42",
    "@types/picomatch": "^4.0.3",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.4.1",
    "eslint-plugin-functional": "^10.0.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  }
}
